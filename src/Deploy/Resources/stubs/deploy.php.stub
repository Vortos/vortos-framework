<?php

declare(strict_types=1);

use Vortos\Deploy\Definition\DeploymentDefinition;

return DeploymentDefinition::create()
    ->host('ssh-compose')
    ->registry('dockerhub')
    ->ci('github')
    ->secrets('env')
    ->monitoring('grafana')
    ->notifiers([])
    ->credential('ssh-key')
    ->strategy('blue-green')
    ->arch('linux/arm64')
    ->autoRollback(true)
    ->build();
