{% extends 'layout/base.html.twig' %}
{% block title %}Edit — {{ schedule.name }}{% endblock %}
{% block content %}
<h1>Edit Schedule: {{ schedule.name }}</h1>

{% if schedule.source.value == 'static' %}
<div class="alert alert-warning">Static schedules cannot be edited here. Modify the <code>#[Scheduled]</code> attribute instead.</div>
{% else %}

{% if errors %}
<div class="alert alert-error">
    {% for field, msg in errors %}<p><strong>{{ field }}:</strong> {{ msg }}</p>{% endfor %}
</div>
{% endif %}

<form method="POST" action="{{ prefix }}/{{ schedule.id }}/edit">
    <div class="form-group">
        <label>Name (read-only)</label>
        <input type="text" value="{{ schedule.name }}" disabled>
    </div>

    <div class="form-group">
        <label for="cron">Cron Expression <span class="required">*</span></label>
        <input type="text" id="cron" name="cron" value="{{ schedule.trigger.describe() }}" required
               hx-get="{{ prefix }}/preview/trigger" hx-trigger="keyup changed delay:400ms"
               hx-include="[name='cron'],[name='timezone']" hx-target="#trigger-preview">
    </div>

    <div id="trigger-preview"></div>

    <div class="form-group">
        <label for="timezone">Timezone</label>
        <input type="text" id="timezone" name="timezone" value="{{ schedule.timezone.getName() }}">
    </div>

    <div class="form-group">
        <label for="command">Command Class <span class="required">*</span></label>
        <input type="text" id="command" name="command" value="{{ schedule.command.class }}" required>
    </div>

    <div class="form-group">
        <label for="misfire">Misfire Policy</label>
        <select id="misfire" name="misfire">
            <option value="skip" {% if schedule.misfire.value == 'skip' %}selected{% endif %}>Skip</option>
            <option value="fire-and-proceed" {% if schedule.misfire.value == 'fire-and-proceed' %}selected{% endif %}>Fire and Proceed</option>
        </select>
    </div>

    <div class="form-group">
        <label for="overlap">Overlap Policy</label>
        <select id="overlap" name="overlap">
            <option value="skip" {% if schedule.overlap.value == 'skip' %}selected{% endif %}>Skip</option>
            <option value="queue" {% if schedule.overlap.value == 'queue' %}selected{% endif %}>Queue</option>
        </select>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" id="sensitive" name="sensitive" value="1" {% if schedule.sensitive %}checked{% endif %}>
        <label for="sensitive">Sensitive (requires 4-eyes approval for run-now)</label>
    </div>

    <div class="form-group">
        <label for="reason">Reason for change</label>
        <input type="text" id="reason" name="reason" placeholder="Optional change reason (audit log)">
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="{{ prefix }}/{{ schedule.id }}" class="btn">Cancel</a>
    </div>
</form>
{% endif %}
{% endblock %}
