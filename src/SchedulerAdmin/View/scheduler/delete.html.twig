{% extends 'layout/base.html.twig' %}
{% block title %}Delete — {{ schedule.name }}{% endblock %}
{% block content %}
<h1>Delete Schedule: {{ schedule.name }}</h1>

{% if schedule.source.value == 'static' %}
<div class="alert alert-error">Static schedules cannot be deleted here.</div>
<a href="{{ prefix }}/{{ schedule.id }}" class="btn">Back</a>
{% else %}
<div class="alert alert-danger">
    <strong>Warning:</strong> This will permanently delete the schedule.
    Run history is preserved. This action cannot be undone.
</div>

<form method="POST" action="{{ prefix }}/{{ schedule.id }}/delete">
    <div class="form-group">
        <label for="reason">Reason for deletion (audit log)</label>
        <input type="text" id="reason" name="reason" placeholder="Required for audit trail">
    </div>
    <div class="form-actions">
        <button type="submit" class="btn btn-danger">Confirm Delete</button>
        <a href="{{ prefix }}/{{ schedule.id }}" class="btn">Cancel</a>
    </div>
</form>
{% endif %}
{% endblock %}
