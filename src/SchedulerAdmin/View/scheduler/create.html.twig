{% extends 'layout/base.html.twig' %}
{% block title %}New Schedule{% endblock %}
{% block content %}
<h1>New Schedule</h1>

{% if errors %}
<div class="alert alert-error">
    {% for field, msg in errors %}<p><strong>{{ field }}:</strong> {{ msg }}</p>{% endfor %}
</div>
{% endif %}

<form method="POST" action="{{ prefix }}/create">
    <div class="form-group">
        <label for="name">Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" value="{{ values.name ?? '' }}" required
               pattern="[a-z0-9][a-z0-9_-]*">
        <small>Lowercase, numbers, hyphens, underscores.</small>
    </div>

    <div class="form-group">
        <label for="cron">Cron Expression <span class="required">*</span></label>
        <input type="text" id="cron" name="cron" value="{{ values.cron ?? '' }}" required
               hx-get="{{ prefix }}/preview/trigger" hx-trigger="keyup changed delay:400ms"
               hx-include="[name='cron'],[name='timezone']" hx-target="#trigger-preview">
    </div>

    <div id="trigger-preview"></div>

    <div class="form-group">
        <label for="timezone">Timezone</label>
        <input type="text" id="timezone" name="timezone" value="{{ values.timezone ?? 'UTC' }}">
    </div>

    <div class="form-group">
        <label for="command">Command Class <span class="required">*</span></label>
        <input type="text" id="command" name="command" value="{{ values.command ?? '' }}" required>
    </div>

    <div class="form-group">
        <label for="misfire">Misfire Policy</label>
        <select id="misfire" name="misfire">
            <option value="skip">Skip</option>
            <option value="fire-and-proceed">Fire and Proceed</option>
        </select>
    </div>

    <div class="form-group">
        <label for="overlap">Overlap Policy</label>
        <select id="overlap" name="overlap">
            <option value="skip">Skip</option>
            <option value="queue">Queue</option>
        </select>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" id="sensitive" name="sensitive" value="1"
               {% if values.sensitive ?? false %}checked{% endif %}>
        <label for="sensitive">Sensitive (requires 4-eyes approval for run-now)</label>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Schedule</button>
        <a href="{{ prefix }}" class="btn">Cancel</a>
    </div>
</form>
{% endblock %}
