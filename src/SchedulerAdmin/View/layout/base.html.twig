<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Scheduler Admin{% endblock %} — Vortos</title>
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <script nonce="{{ csp_nonce() }}">
        document.addEventListener('htmx:configRequest', function(e) {
            e.detail.headers['X-CSRF-Token'] = document.querySelector('meta[name="csrf-token"]').content;
        });
    </script>
    <link rel="stylesheet" href="{{ vite_asset('main.css') }}" nonce="{{ csp_nonce() }}">
</head>
<body>
<nav>
    <a href="{{ prefix }}">Dashboard</a>
    <a href="{{ prefix }}/approvals">Approvals</a>
    <a href="{{ prefix }}/audit">Audit Log</a>
    <a href="{{ prefix }}/observability">Observability</a>
</nav>
<main>
    {% block content %}{% endblock %}
</main>
<script src="{{ vite_asset('main.js') }}" nonce="{{ csp_nonce() }}" defer></script>
</body>
</html>
