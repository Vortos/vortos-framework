{
    "name": "vortos/vortos-feature-flags-admin",
    "description": "Admin console for Vortos Feature Flags — management UI, RBAC-gated, HTMX + React islands.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "vortos/vortos-feature-flags": "^1.0",
        "vortos/vortos-http": "^1.0",
        "vortos/vortos-auth": "^1.0",
        "vortos/vortos-authorization": "^1.0",
        "twig/twig": "^3.0"
    },
    "extra": {
        "vortos": {
            "package": "Vortos\\FeatureFlagsAdmin\\DependencyInjection\\FeatureFlagsAdminPackage",
            "order": 100,
            "public-dir": "Public"
        }
    },
    "autoload": {
        "psr-4": {
            "Vortos\\FeatureFlagsAdmin\\": ""
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vortos\\FeatureFlagsAdmin\\Tests\\": "Tests/"
        }
    }
}
