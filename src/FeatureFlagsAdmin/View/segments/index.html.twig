{% extends "layout/base.html.twig" %}

{% block title %}Segments{% endblock %}

{% block content %}
<div class="page-header">
    <h1 class="page-title">Segments</h1>
    <span class="text-muted" style="font-size:0.8125rem">{{ segments|length }} segments</span>
</div>

{% if segments is empty %}
    <div class="empty-state">No segments defined yet.</div>
{% else %}
<div class="card">
    <table>
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Rules</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for segment in segments %}
            <tr>
                <td class="mono text-bright">{{ segment.name }}</td>
                <td class="text-muted" style="font-size:0.8125rem">{{ segment.description|default('-') }}</td>
                <td class="text-muted">{{ segment.rules|length }}</td>
                <td>
                    <a href="{{ prefix }}/segments/{{ segment.id }}" class="btn btn-ghost btn-sm">Edit</a>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endif %}
{% endblock %}
