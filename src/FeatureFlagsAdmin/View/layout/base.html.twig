<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Feature Flags{% endblock %} — Vortos Admin</title>
    <meta name="csrf-token" content="{{ csrf_token() }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
    <style nonce="{{ csp_nonce() }}">
        :root {
            --bg-void: #050505;
            --bg-surface: #0f0f11;
            --bg-panel: #18181b;
            --bg-active: #27272a;
            --border-dim: #27272a;
            --border-mid: #3f3f46;
            --text-bright: #ffffff;
            --text-main: #e4e4e7;
            --text-muted: #a1a1aa;
            --text-dim: #71717a;
            --accent-primary: #6366f1;
            --accent-primary-hover: #818cf8;
            --accent-success: #22c55e;
            --accent-warning: #f59e0b;
            --accent-danger: #ef4444;
            --accent-danger-hover: #dc2626;
            --accent-info: #3b82f6;
            --radius-sm: 4px;
            --radius-md: 6px;
            --radius-lg: 8px;
            --font-sans: 'Inter', system-ui, -apple-system, sans-serif;
            --font-mono: 'JetBrains Mono', ui-monospace, monospace;
        }
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: var(--font-sans);
            background: var(--bg-void);
            color: var(--text-main);
            line-height: 1.5;
            min-height: 100vh;
        }
        .admin-layout { display: flex; min-height: 100vh; }
        .admin-sidebar {
            width: 240px;
            background: var(--bg-surface);
            border-right: 1px solid var(--border-dim);
            padding: 1rem 0;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            overflow-y: auto;
            z-index: 100;
        }
        .admin-sidebar-brand {
            padding: 0.75rem 1.25rem;
            font-weight: 800;
            font-size: 0.875rem;
            color: var(--text-bright);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-dim);
            margin-bottom: 0.5rem;
        }
        .admin-nav { list-style: none; }
        .admin-nav-item {
            display: block;
            padding: 0.5rem 1.25rem;
            color: var(--text-muted);
            text-decoration: none;
            font-size: 0.875rem;
            font-weight: 500;
            transition: color 0.15s, background 0.15s;
        }
        .admin-nav-item:hover { color: var(--text-bright); background: var(--bg-active); }
        .admin-nav-item.active { color: var(--accent-primary); background: var(--bg-panel); }
        .admin-nav-section {
            padding: 1rem 1.25rem 0.25rem;
            font-size: 0.6875rem;
            font-weight: 600;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .admin-main {
            margin-left: 240px;
            flex: 1;
            padding: 1.5rem 2rem;
            max-width: calc(100vw - 240px);
        }
        .page-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 1.5rem;
        }
        .page-title { font-size: 1.5rem; font-weight: 700; color: var(--text-bright); }
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 0.375rem;
            padding: 0.5rem 1rem;
            font-size: 0.8125rem;
            font-weight: 600;
            font-family: var(--font-sans);
            border-radius: var(--radius-md);
            border: 1px solid transparent;
            cursor: pointer;
            transition: all 0.15s;
            text-decoration: none;
        }
        .btn-primary {
            background: var(--accent-primary);
            color: #fff;
        }
        .btn-primary:hover { background: var(--accent-primary-hover); }
        .btn-danger {
            background: var(--accent-danger);
            color: #fff;
        }
        .btn-danger:hover { background: var(--accent-danger-hover); }
        .btn-ghost {
            background: transparent;
            color: var(--text-muted);
            border-color: var(--border-mid);
        }
        .btn-ghost:hover { color: var(--text-bright); border-color: var(--text-dim); }
        .btn-sm { padding: 0.25rem 0.625rem; font-size: 0.75rem; }
        .card {
            background: var(--bg-surface);
            border: 1px solid var(--border-dim);
            border-radius: var(--radius-lg);
            overflow: hidden;
        }
        .card-header {
            padding: 0.75rem 1rem;
            border-bottom: 1px solid var(--border-dim);
            font-weight: 600;
            font-size: 0.875rem;
            color: var(--text-bright);
        }
        .card-body { padding: 1rem; }
        table { width: 100%; border-collapse: collapse; }
        th {
            text-align: left;
            padding: 0.625rem 1rem;
            font-size: 0.6875rem;
            font-weight: 600;
            color: var(--text-dim);
            text-transform: uppercase;
            letter-spacing: 0.05em;
            border-bottom: 1px solid var(--border-dim);
        }
        td {
            padding: 0.625rem 1rem;
            font-size: 0.8125rem;
            border-bottom: 1px solid var(--border-dim);
            vertical-align: middle;
        }
        tr:last-child td { border-bottom: none; }
        tr:hover td { background: var(--bg-panel); }
        .badge {
            display: inline-flex;
            align-items: center;
            padding: 0.125rem 0.5rem;
            font-size: 0.6875rem;
            font-weight: 600;
            border-radius: 9999px;
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .badge-success { background: rgba(34,197,94,0.15); color: var(--accent-success); }
        .badge-danger { background: rgba(239,68,68,0.15); color: var(--accent-danger); }
        .badge-warning { background: rgba(245,158,11,0.15); color: var(--accent-warning); }
        .badge-info { background: rgba(59,130,246,0.15); color: var(--accent-info); }
        .badge-muted { background: var(--bg-active); color: var(--text-dim); }
        .toggle {
            position: relative;
            width: 36px;
            height: 20px;
            display: inline-block;
        }
        .toggle input { opacity: 0; width: 0; height: 0; }
        .toggle-slider {
            position: absolute;
            cursor: pointer;
            inset: 0;
            background: var(--bg-active);
            border-radius: 10px;
            transition: 0.2s;
        }
        .toggle-slider::before {
            content: '';
            position: absolute;
            width: 16px;
            height: 16px;
            left: 2px;
            bottom: 2px;
            background: var(--text-muted);
            border-radius: 50%;
            transition: 0.2s;
        }
        .toggle input:checked + .toggle-slider { background: var(--accent-success); }
        .toggle input:checked + .toggle-slider::before {
            transform: translateX(16px);
            background: #fff;
        }
        .input {
            background: var(--bg-panel);
            border: 1px solid var(--border-mid);
            border-radius: var(--radius-md);
            padding: 0.5rem 0.75rem;
            font-size: 0.8125rem;
            color: var(--text-main);
            font-family: var(--font-sans);
            outline: none;
            width: 100%;
            transition: border-color 0.15s;
        }
        .input:focus { border-color: var(--accent-primary); }
        .input::placeholder { color: var(--text-dim); }
        .flash {
            padding: 0.75rem 1rem;
            border-radius: var(--radius-md);
            font-size: 0.8125rem;
            margin-bottom: 1rem;
            border: 1px solid;
        }
        .flash-success { background: rgba(34,197,94,0.1); border-color: rgba(34,197,94,0.3); color: var(--accent-success); }
        .flash-error { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.3); color: var(--accent-danger); }
        .flash-warning { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.3); color: var(--accent-warning); }
        .env-tabs { display: flex; gap: 0; border-bottom: 1px solid var(--border-dim); margin-bottom: 1rem; }
        .env-tab {
            padding: 0.5rem 1rem;
            font-size: 0.8125rem;
            font-weight: 500;
            color: var(--text-muted);
            text-decoration: none;
            border-bottom: 2px solid transparent;
            transition: all 0.15s;
            cursor: pointer;
            background: none;
            border-top: none;
            border-left: none;
            border-right: none;
            font-family: var(--font-sans);
        }
        .env-tab:hover { color: var(--text-bright); }
        .env-tab.active { color: var(--accent-primary); border-bottom-color: var(--accent-primary); }
        .mono { font-family: var(--font-mono); font-size: 0.8125rem; }
        .text-dim { color: var(--text-dim); }
        .text-muted { color: var(--text-muted); }
        .text-bright { color: var(--text-bright); }
        .mt-1 { margin-top: 0.25rem; }
        .mt-2 { margin-top: 0.5rem; }
        .mt-4 { margin-top: 1rem; }
        .mb-4 { margin-bottom: 1rem; }
        .flex { display: flex; }
        .items-center { align-items: center; }
        .gap-2 { gap: 0.5rem; }
        .gap-3 { gap: 0.75rem; }
        .justify-between { justify-content: space-between; }
        .w-full { width: 100%; }
        .empty-state {
            text-align: center;
            padding: 3rem 1rem;
            color: var(--text-dim);
            font-size: 0.875rem;
        }
        .rollout-bar {
            height: 6px;
            background: var(--bg-active);
            border-radius: 3px;
            overflow: hidden;
            width: 100px;
        }
        .rollout-fill {
            height: 100%;
            background: var(--accent-primary);
            border-radius: 3px;
            transition: width 0.3s;
        }
        .diff-add { color: var(--accent-success); background: rgba(34,197,94,0.08); }
        .diff-remove { color: var(--accent-danger); background: rgba(239,68,68,0.08); }
        .diff-line { padding: 0.125rem 0.5rem; font-family: var(--font-mono); font-size: 0.75rem; white-space: pre-wrap; }
        .confirm-dialog {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.7);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .confirm-dialog.active { display: flex; }
        .confirm-box {
            background: var(--bg-surface);
            border: 1px solid var(--border-mid);
            border-radius: var(--radius-lg);
            padding: 1.5rem;
            max-width: 420px;
            width: 100%;
        }
        .search-box { position: relative; max-width: 320px; }
        .pagination {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-top: 1rem;
            justify-content: flex-end;
        }
    </style>
    {% block head %}{% endblock %}
</head>
<body>
    <div class="admin-layout">
        <nav class="admin-sidebar">
            <div class="admin-sidebar-brand">Vortos Flags</div>
            <div class="admin-nav-section">Management</div>
            <ul class="admin-nav">
                <li><a href="{{ prefix }}" class="admin-nav-item{% if active_nav == 'dashboard' %} active{% endif %}">Dashboard</a></li>
                <li><a href="{{ prefix }}/segments" class="admin-nav-item{% if active_nav == 'segments' %} active{% endif %}">Segments</a></li>
            </ul>
            <div class="admin-nav-section">Governance</div>
            <ul class="admin-nav">
                <li><a href="{{ prefix }}/approvals" class="admin-nav-item{% if active_nav == 'approvals' %} active{% endif %}">Approvals</a></li>
                <li><a href="{{ prefix }}/history" class="admin-nav-item{% if active_nav == 'history' %} active{% endif %}">History</a></li>
            </ul>
            <div class="admin-nav-section">Operations</div>
            <ul class="admin-nav">
                <li><a href="{{ prefix }}/kill-switch" class="admin-nav-item{% if active_nav == 'kill_switch' %} active{% endif %}">Kill Switch</a></li>
                <li><a href="{{ prefix }}/env-compare" class="admin-nav-item{% if active_nav == 'env_compare' %} active{% endif %}">Env Compare</a></li>
                <li><a href="{{ prefix }}/insights" class="admin-nav-item{% if active_nav == 'insights' %} active{% endif %}">Insights</a></li>
            </ul>
        </nav>
        <main class="admin-main">
            {% block flash %}
                {% if flash_message is defined and flash_message %}
                    <div class="flash flash-{{ flash_type|default('success') }}">{{ flash_message }}</div>
                {% endif %}
            {% endblock %}
            {% block content %}{% endblock %}
        </main>
    </div>
    <script nonce="{{ csp_nonce() }}">
        document.body.addEventListener('htmx:configRequest', function(e) {
            e.detail.headers['X-CSRF-Token'] = document.querySelector('meta[name="csrf-token"]').content;
        });
    </script>
    <script src="https://unpkg.com/htmx.org@2.0.4" nonce="{{ csp_nonce() }}"></script>
    <script src="https://unpkg.com/htmx-ext-sse@2.3.0/sse.js" nonce="{{ csp_nonce() }}"></script>
    {# React island bundle — hashed via Vite manifest, CSP-nonce-compatible, type=module avoids eval #}
    <script type="module" src="{{ vite_asset('src/main.tsx') }}" nonce="{{ csp_nonce() }}"></script>
    {% block scripts %}{% endblock %}
</body>
</html>
