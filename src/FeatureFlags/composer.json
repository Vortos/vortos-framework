{
    "name": "vortos/vortos-feature-flags",
    "description": "Vortos feature flags — percentage rollout, user targeting, attribute rules, kill switch",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Vortos\\FeatureFlags\\": ""
        }
    },
    "require": {
        "php": ">=8.2",
        "vortos/vortos-foundation": "^1.0",
        "vortos/vortos-metrics": "^1.0",
        "vortos/vortos-domain": "^1.0",
        "vortos/vortos-messaging": "^1.0",
        "vortos/vortos-persistence": "^1.0",
        "vortos/vortos-persistence-dbal": "^1.0",
        "vortos/vortos-observability": "^1.0",
        "vortos/vortos-auth": "^1.0",
        "vortos/vortos-authorization": "^1.0",
        "vortos/vortos-cache": "^1.0",
        "doctrine/dbal": "^4.0",
        "psr/clock": "^1.0",
        "psr/log": "^3.0",
        "vortos/vortos-http": "^1.0",
        "symfony/uid": "^7.0"
    },
    "suggest": {
        "vortos/vortos-persistence-mongo": "Optional: store the flag audit-log / state-view read models in MongoDB instead of the default relational (DBAL) tables."
    },
    "extra": {
        "vortos": {
            "package": "Vortos\\FeatureFlags\\DependencyInjection\\FeatureFlagsPackage",
            "order": 120
        }
    }
}
