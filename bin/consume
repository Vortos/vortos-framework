# !/usr/bin/env php
<?php

set_time_limit(0);

$config = require __DIR__ . '/../bootstrap/app.php';

use Vortos\Foundation\Runner;

$groupId = $argv[1] ?? throw new InvalidArgumentException("Missing group_id");

$runner = new Runner(...$config, context: 'console');

try {
    $container = $runner->getContainer();

    echo " [*] Messenger consumer worker started. Group: {$groupId}. Press Ctrl+C to stop.\n";
    $container->get('vortos.consumer')->run($groupId);
} catch (\Throwable $e) {
    fwrite(STDERR, "Worker Error: " . $e->getMessage() . "\n");
    exit(1);
} finally {
    $runner->cleanUp();
}
